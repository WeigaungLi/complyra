project_name         = "complyra"
aws_region           = "ap-southeast-1"
vpc_cidr             = "10.40.0.0/16"
availability_zones   = ["ap-southeast-1a", "ap-southeast-1b"]
public_subnet_cidrs  = ["10.40.1.0/24", "10.40.2.0/24"]
private_subnet_cidrs = ["10.40.11.0/24", "10.40.12.0/24"]

# Networking / Load balancing
acm_certificate_arn = ""

# Image source
ecr_registry = ""
image_tag    = "latest"

# Database
db_name          = "complyra"
db_username      = "app"
db_password      = "replace-with-strong-password"
db_instance_class = "db.t3.medium"
db_engine_version = "16.3"
db_multi_az       = true

# Cache
redis_node_type                   = "cache.t3.small"
redis_num_cache_clusters          = 1
redis_at_rest_encryption_enabled  = true
redis_transit_encryption_enabled  = true
redis_auth_token                  = ""

# App runtime
app_env              = "prod"
app_cors_origins     = "https://app.example.com"
app_trusted_hosts    = "api.example.com,app.example.com"
app_qdrant_url       = "http://qdrant.internal:6333"
app_ollama_base_url  = "http://ollama.internal:11434"
app_ollama_model     = "qwen2.5:3b-instruct"
app_require_approval = true

# Optional secrets
jwt_secret_value = ""
app_sentry_dsn   = ""

# ECS service sizes
api_desired_count    = 2
worker_desired_count = 1
web_desired_count    = 2

# CloudWatch Synthetics
enable_synthetics            = true
synthetics_start_canary      = false
synthetics_schedule_expression = "rate(5 minutes)"
synthetics_api_base_url      = "https://api.example.com"
synthetics_username          = "demo"
synthetics_password          = "replace-with-canary-password"
synthetics_tenant_id         = "default"
